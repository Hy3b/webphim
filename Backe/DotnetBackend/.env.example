# ── Database (MySQL) ──────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306           
DB_NAME=webphim
DB_USER=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD

# ── JWT (bắt buộc >= 32 ký tự) ───────────────────
JWT_SECRET=YOUR_SECURE_JWT_SECRET_STRING_AT_LEAST_32_CHARS

# ── Redis ─────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ── SePay Webhook (để trống nếu chưa dùng tới) ────
SEPAY_WEBHOOK_SECRET=YOUR_SEPAY_WEBHOOK_SECRET

# ── Resend Email API ──────────────────────────────
RESEND_API_KEY=YOUR_RESEND_API_KEY

# ── Dynamic Domain Setup (Laptop Migration) ───────
# URL của Frontend dùng để kích hoạt tài khoản qua Email
FRONTEND_URL=https://webphim.YOUR_LAPTOP_DOMAIN.id.vn
# Danh sách domain được phép gọi API (CORS) - phân cách bởi dấu phẩy
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,https://webphim.YOUR_LAPTOP_DOMAIN.id.vn,https://www.YOUR_LAPTOP_DOMAIN.id.vn

# ── Email Setup (Resend) ─────────────────────────
# Email gửi đi dùng cho kích hoạt tài khoản & quên mật khẩu
EMAIL=MyCinema <onboarding@resend.dev>
