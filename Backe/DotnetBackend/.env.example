# ── Database (MySQL) ──────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3307           # Cổng 3307 nếu chạy MySQL qua Docker, 3306 nếu chạy local
DB_NAME=webphim
DB_USER=root
DB_PASSWORD= 123456   # Thay bằng password MySQL thực của bạn

# ── JWT (bắt buộc >= 32 ký tự) ───────────────────
# Tạo một chuỗi ngẫu nhiên dài ít nhất 32 ký tự
JWT_SECRET=webphim_super_secret_key_2024_at_least_32_chars

# ── Redis ─────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=webphim-secret-redis

# ── SePay Webhook (để trống nếu chưa dùng) ────────
SEPAY_WEBHOOK_SECRET=
