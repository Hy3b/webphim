{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "WebPhimApi",
    "Audience": "WebPhimClient",
    "ExpirationDays": 7
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};User=${DB_USER};Password=${DB_PASSWORD};"
  },
  "Redis": {
    "ConnectionString": "${REDIS_HOST}:${REDIS_PORT},password=${REDIS_PASSWORD}"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://127.0.0.1:5173",
      "http://127.0.0.1:5174",
      "http://localhost:3000",
      "https://backe-live.hanhfine.id.vn",
      "https://hanh.hanhfine.id.vn"
    ]
  }
}
